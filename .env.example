# ── Twitter / X API ───────────────────────────────────────────────────────────
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ── Reddit API ────────────────────────────────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=SentimentBot/1.0

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=sentiment_user
POSTGRES_PASSWORD=sentiment_pass
POSTGRES_DB=sentimentdb
POSTGRES_URL=postgresql://sentiment_user:sentiment_pass@localhost:5432/sentimentdb

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_RAW=raw-social-posts
KAFKA_TOPIC_ENRICHED=enriched-sentiment
KAFKA_CONSUMER_GROUP=sentiment-consumer-group

# ── MinIO / S3 ────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_password
MINIO_ENDPOINT=localhost:9000
MINIO_BUCKET=sentiment-models

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
MODEL_PATH=models/sentiment_model.pkl
API_PORT=8000
